{
  "layer": "top",
  "position": "top",
  "height": 32,
  "spacing": 2,
  "margin-top": 9,
  "margin-bottom": 1,
  "margin-left": 8,
  "margin-right": 8,
  "padding": 4,
  
  "modules-left": [
    "custom/arch-launcher",
    "custom/mpris-scroll",
    // "hyprland/window"
    "custom/cpu-temp"
  ],
  
  "modules-center": [
    "hyprland/workspaces"
  ],
  
  "modules-right": [
    "hyprland/language",
    "tray",
    // "custom/arch-update",
    "group/system",
    "custom/notification",
    "clock"
    // "custom/powermenu"
  ],
  
  "tray": {
    "icon-size": 12,
    "spacing": 8
  },
  
  "custom/arch-launcher": {
    "format": " ",
    "exec": "$HOME/bin/waybar/system-update.sh check",
    "return-type": "json",
    "interval": 1500,
    "tooltip": "App launcher",
    "on-click": "rofi -show drun -config ~/.config/rofi/launcher/launcher.rasi", // App Launcher
    "on-click-right": "$HOME/bin/waybar/system-update.sh up", // Update script
  },
  
  "hyprland/workspaces": {
    "format": "{name}",
    "format-icons": {
      "active": "󰮯",
      "default": "",
      "urgent": "󱧦"
    },
    "persistent_workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": [],
      "7": [],
      "8": [],
      "9": []
    },
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "all-outputs": true,
    "show-special": false
  },
  
  "hyprland/window": {
    "format": "<span color='#7aa2f7'>  {title}</span>",
    "max-length": 25,
    "truncate": true,
    "ellipsize": true,
    "rewrite": {
      "(.*) - Zen Browser": "🌎 $1",
      "(.*) - fish": " [$1]",
      "(.*) — Chromium": "🌐 $1",
      "(.*) — Brave": "🦁 $1"
    }
  },
  
  "hyprland/language": {
    "format": "{}",
    "format-ru": "RU ",
    "format-en": "US ",
    "on-click": "hyprctl switchxkblayout at-translated-set-2-keyboard next"
  },
  
  "custom/mpris-scroll": {
    "format": "{}",
    "exec": "$HOME/bin/waybar/mpris-scroll.sh",
    "return-type": "json",
    "interval": 1,
    "on-click": "playerctl play-pause",
    "on-click-right": "$HOME/.config/rofi/media/rofi-media.sh",
    "on-scroll-up": "playerctl next",
    "on-scroll-down": "playerctl previous"
  },

  
  "custom/cpu-temp": {
    "format": "{}",
    "exec": "$HOME/bin/waybar/cpu-temp.sh",
    "return-type": "json",
    "interval": 2,
    "on-click": "neohtop",
    "on-click-right": "foot btop"
  },
  
  "custom/arch-update": {
    "format": "󰏗",
    "exec": "$HOME/bin/waybar/system-update.sh check",
    "return-type": "json",
    "interval": 1500,
    "on-click": "$HOME/bin/waybar/system-update.sh up",
  },
  
  "custom/system-wrap": {
    "format": "󰳝",
    "tooltip-format": "System Controls"
  },
  
  "group/system": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 800,
      "transition-left-to-right": true
    },
    "modules": [
      "custom/system-wrap",
      "power-profiles-daemon",
      "custom/clipboard",
      "backlight",
      "wireplumber",
      "custom/network",
      "bluetooth"
    ]
  },
  
  "custom/clipboard": {
    "format": "󰅍",
    "tooltip": "Clipboard",
    "on-click": "rofi -show clipboard -config ~/.config/rofi/clipboard/clipboard.rasi",
    // "on-click-right": "cliphist wipe"
  },
  
  "custom/powermenu": {
    "format": "⏻",
    "tooltip": "Power Menu",
    "on-click": "$HOME/bin/waybar/powermenu1.sh"
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "<span foreground='#f7768e'><sup></sup></span>",
      "none": "",
      "dnd-notification": "󰂛<span foreground='#f7768e'><sup></sup></span>",
      "dnd-none": "󰂛",
      "inhibited-notification": "<span foreground='#f7768e'><sup></sup></span>",
      "inhibited-none": "",
      "dnd-inhibited-notification": "󰂛<span foreground='#f7768e'><sup></sup></span>",
      "dnd-inhibited-none": "󰂛"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  "clock": {
    "format": "󰥔 {:%H:%M}",
    "format-alt": "󰥔 {:%H:%M 󰃮 %d/%m}", 
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#d3c6aa'><b>{}</b></span>",
        "days": "<span color='#e67e80'>{}</span>",
        "weeks": "<span color='#a7c080'><b>W{}</b></span>",
        "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
        "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "foot calcure",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },
  
  "custom/network": {
    "format": "{}",
    "exec": "~/bin/waybar/network.sh",
    "return-type": "json",
    "interval": 3,
    "tooltip": true,
    "on-click": "nmgui",
    "on-click-right": "$HOME/.config/rofi/network/rofi-network.sh",
  },
  
  "wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": "󰝟",
    "format-icons": ["󰕿", "󰖀", "󰕾"],
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-scroll-up": "swayosd-client --output-volume +1",
    "on-scroll-down": "swayosd-client --output-volume -1",
    "on-click-right": "pavucontrol"
  },
  
  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["󰃞", "󰃟", "󰃠"],
    "on-scroll-up": "swayosd-client --brightness +1",
    "on-scroll-down": "swayosd-client --brightness -1",
    "on-click": "$HOME/.config/rofi/nightshift/rofi-nightshift.sh"
  },
  
  "bluetooth": {
    "format": "󰂯",
    "format-disabled": "󰂲",
    "format-connected": "󰂱",
    "tooltip-format": "{device_alias}",
    "tooltip-format-connected": "{device_alias} {device_battery_percentage}%",
    "tooltip-format-enumerate-connected": "{device_alias} {device_battery_percentage}%",
    "on-click": "blueman-manager",
    "on-click-right": "$HOME/.config/rofi/network/rofi-bluetooth.sh"
  },
  
  "power-profiles-daemon": {
    "format": "{icon}",
    "format-icons": {
      "power-saver": "󰾆",
      "balanced": "󰾅",
      "performance": "󰓅"
    },
    "on-click": "powerprofilesctl set $(powerprofilesctl list | grep -v '*' | head -1 | xargs)"
  }
}
