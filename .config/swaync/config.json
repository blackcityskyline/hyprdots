{
  "$schema": "/etc/xdg/swaync/configSchema.json",
  "ignore-gtk-theme": true,
  "positionX": "right",
  "positionY": "top",
  "layer": "overlay",
  "control-center-layer": "top",
  "layer-shell": true,
  "layer-shell-cover-screen": false,
  "cssPriority": "user",
  "control-center-margin-top": 0,
  "control-center-margin-bottom": 0,
  "control-center-margin-right": 0,
  "control-center-margin-left": 0,
  "notification-2fa-action": true,
  "notification-inline-replies": false,
  "notification-body-image-height": 100,
  "notification-body-image-width": 200,
  "timeout": 7,
  "timeout-low": 5,
  "timeout-critical": 10,
  "fit-to-screen": true,
  "relative-timestamps": true,
  "control-center-width": 450,
  "control-center-height": 600,
  "notification-window-width": 450,
  "keyboard-shortcuts": true,
  "notification-grouping": true,
  "image-visibility": "when-available",
  "transition-time": 200,
  "hide-on-clear": false,
  "hide-on-action": true,
  "text-empty": "No Notifications",
  "script-fail-notify": true,
  "notification-visibility": {
    "example-name": {
      "state": "muted",
      "urgency": "Low",
      "app-name": "Spotify"
    }
  },
  "widgets": [
    "buttons-grid",
    "mpris",
    "notifications"
  ],
  "widget-config": {
    "notifications": {
      "vexpand": true
    },
    "title": {
      "text": "Notifications",
      "clear-all-button": true,
      "button-text": "Clear All"
    },
    "dnd": {
      "text": "Do Not Disturb"
    },
    "mpris": {
      "autohide": true,
      "show-album-art": "always",
      "loop-carousel": true,
      "blacklist": [
        "org.mpris.MediaPlayer2.mpv"
      ]
    },
    "backlight": {
      "device": "intel_backlight",
      "label": "󰃟",
      "slider": true,
      "min": 5
    },
    "volume": {
      "device": "default",
      "label": "󰕾",
      "slider": true
    },
    "buttons-grid": {
      "buttons-per-row": 5,
      "actions": [
        {
          "label": "󰖩",
          "type": "toggle",
          "active": true,
          "command": "swaync-client -t -sw;sh -c 'nmgui'",
          "update-command": "sh -c 'nmcli -t -f STATE general | grep -q connected && echo true || echo false'"
        },
        {
          "label": "󰖔",
          "type": "toggle",
          "active": true,
          "command": "bash ~/.config/rofi/nightshift/rofi-nightshift.sh",
          "update-command": "sh -c 'pgrep -x wlsunset > /dev/null && echo true || echo false'"
        },
        {
          "label": "",
          "type": "button",
          "active": true,
          "command": "swaync-client -t -sw;sh -c 'rofi -show clipboard -config ~/.config/rofi/clipboard/clipboard.rasi'"
        },
        {
          "label": "󱣵",
          "type": "toggle",
          "active": false,
          "command": "bash ~/bin/others/screencast_toggle",
          "update-command": "sh -c '[ -f /tmp/screencast.pid ] && kill -0 $(cat /tmp/screencast.pid) 2>/dev/null && echo true || echo false'"
        },
        {
          "label": "󰐥",
          "type": "button",
          "active": true,
          "command": "swaync-client -t -sw;sh -c '~/bin/waybar/powermenu1.sh'"
        },
        {
          "label": "󰂯",
          "type": "toggle",
          "active": true,
          "command": "swaync-client -t -sw;sh -c 'adw-bluetooth'",
          "update-command": "sh -c 'bluetoothctl show | grep -q \"Powered: yes\" && echo true || echo false'"
        },
        {
          "label": "󰕾",
          "type": "toggle",
          "active": true,
          "command": "swaync-client -t -sw;sh -c 'pavucontrol'",
          "update-command": "sh -c 'pactl get-default-sink | grep -qiE \"usb|bluez|hdmi|headphone\" && echo true || echo false'"
        },
        {
          "label": "",
          "type": "toggle",
          "active": true,
          "command": "swaync-client -t -sw;sh -c '~/bin/hypr/hyprvisuals'",
          "update-command": "sh -c '~/bin/hypr/hyprvisuals --status'"
        },
        {
          "label": "󰍭",
          "type": "toggle",
          "active": false,
          "command": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
          "update-command": "sh -c 'pactl get-source-mute @DEFAULT_SOURCE@ | grep -q yes && echo true || echo false'"
        },
        {
          "label": "󰅃",
          "type": "button",
          "active": true,
          "command": "bash ~/bin/swaync/widgets_toggle.sh"
        }
      ]
    }
  }
}
