#!/bin/bash
# Rofi script mode — clipboard history via cliphist
#
# ROFI_RETV=0  — show list
# ROFI_RETV=1  — entry selected → decode and copy to clipboard
# ROFI_RETV=10 — Ctrl+D → delete entry from history

if [ "$ROFI_RETV" = "0" ]; then
    cliphist list

elif [ "$ROFI_RETV" = "1" ]; then
    echo "$1" | cliphist decode | wl-copy

elif [ "$ROFI_RETV" = "10" ]; then
    echo "$1" | cliphist delete
    cliphist list
fi
